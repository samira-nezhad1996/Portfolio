@model Application.ViewModels.LastWork.EditLastWorkViewModel
@{
    ViewData["Title"] = "ویرایش رکورد";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
        <h5 class="mb-0">ویرایش رکورد</h5>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>
            بازگشت به لیست
        </a>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post" class="needs-validation" novalidate>
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                خطا در ارسال فرم:
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" required />
                    <div class="invalid-feedback">لطفاً عنوان را وارد کنید.</div>
                </div>

                <div class="col-md-6">
                    <label asp-for="ShortDescription" class="form-label"></label>
                    <textarea asp-for="ShortDescription" class="form-control" rows="3"></textarea>
                    <div class="valid-feedback"></div>
                </div>

                <div class="col-md-6">
                    <label asp-for="StartDate" class="form-label"></label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <div class="valid-feedback"></div>
                </div>

                <div class="col-md-6">
                    <label asp-for="EndDate" class="form-label"></label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <div class="valid-feedback"></div>
                </div>

                <div class="col-12">
                    <label asp-for="Logo" class="form-label"></label>
                    <input asp-for="Logo" class="form-control" />
                    <div class="valid-feedback"></div>
                </div>
            </div>

            <div class="mt-4">
                <button class="btn btn-warning me-2" type="submit">
                    <i class="bi bi-pencil me-1"></i>
                    به‌روزرسانی
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle me-1"></i>
                    لغو
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            'use strict';
            var forms = document.querySelectorAll('.needs-validation');
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault();
                            event.stopPropagation();
                        }
                        form.classList.add('was-validated');
                    }, false);
                });
        })();
    </script>
}
