@model Application.ViewModels.LastWorks.LastWorkViewModel
@{
    ViewData["Title"] = "جزئیات آخرین کار";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">جزئیات</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">بازگشت</a>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h4 class="mb-3">@Model.Title</h4>

                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">توضیح کوتاه</dt>
                    <dd class="col-sm-8">@Model.ShortDescription</dd>

                    <dt class="col-sm-4 text-muted">تاریخ شروع</dt>
                    <dd class="col-sm-8">@Model.StartDate</dd>

                    <dt class="col-sm-4 text-muted">تاریخ پایان</dt>
                    <dd class="col-sm-8">@Model.EndDate</dd>

                    <dt class="col-sm-4 text-muted">لوگو</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrWhiteSpace(Model.Logo))
                        {
                            <img src="@Model.Logo"
                                 alt="لوگو"
                                 class="img-fluid rounded border"
                                 style="max-height:220px; object-fit:contain;" />
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </dd>
                </dl>

                <div class="mt-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="bi bi-pencil me-1"></i>ویرایش
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>بازگشت به لیست
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
