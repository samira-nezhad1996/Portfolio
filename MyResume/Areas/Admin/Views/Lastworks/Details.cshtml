@model Application.ViewModels.LastWork.LastWorkViewModel
@{
    ViewData["Title"] = "جزئیات آخرین کار";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
        <h5 class="mb-0">جزئیات آخرین کار</h5>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-warning me-2">
                <i class="bi bi-pencil me-1"></i>
                ویرایش
            </a>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>
                بازگشت به لیست
            </a>
        </div>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-lg-8">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted">عنوان:</dt>
                    <dd class="col-sm-9 fw-semibold">@Model.Title</dd>

                    <dt class="col-sm-3 text-muted">توضیح کوتاه:</dt>
                    <dd class="col-sm-9">@Model.ShortDescription</dd>

                    <dt class="col-sm-3 text-muted">تاریخ شروع:</dt>
                    <dd class="col-sm-9">@(Model.StartDate.ToString("yyyy-MM-dd") ?? "-")</dd>

                    <dt class="col-sm-3 text-muted">تاریخ پایان:</dt>
                    <dd class="col-sm-9">@(Model.EndDate.ToString("yyyy-MM-dd") ?? "-")</dd>
                </dl>
            </div>
            <div class="col-lg-4 text-center border-start ps-4">
                @if (!string.IsNullOrWhiteSpace(Model.Logo))
                {
                    <img src="@Model.Logo" alt="لوگو" class="img-fluid rounded-3" style="max-height: 150px; max-width: 150px; object-fit: cover;" />
                }
                else
                {
                    <span class="text-muted fs-5">بدون لوگو</span>
                }
            </div>
        </div>
    </div>
</div>
