@model IEnumerable<UserViewModel>
@{
    ViewData["Title"] = "لیست کاربران";
}

<h2 class="mb-3">لیست کاربران</h2>

<a asp-action="Create" class="btn btn-success mb-3">افزودن کاربر جدید</a>

<table class="table table-bordered table-striped text-center">
    <thead class="table-dark">
        <tr>
            <th>نام کامل</th>
            <th>ایمیل</th>
            <th>شماره موبایل</th>
            <th>تاریخ ایجاد</th>
            <th>عملیات</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>@user.Mobile</td>
                <td>@user.CreateDate.ToString("yyyy/MM/dd")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info">جزئیات</a>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">ویرایش</a>
                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('آیا از حذف مطمئن هستید؟');">
                            حذف
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">هیچ کاربری ثبت نشده است.</div>
}
