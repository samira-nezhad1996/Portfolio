@model UserViewModel
@{
    ViewData["Title"] = "افزودن کاربر جدید";
}

<h2>افزودن کاربر جدید</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="FullName" class="form-label">نام کامل</label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label">ایمیل</label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Mobile" class="form-label">شماره موبایل</label>
        <input asp-for="Mobile" class="form-control" />
        <span asp-validation-for="Mobile" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">ثبت</button>
    <a asp-action="Index" class="btn btn-secondary">بازگشت</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
