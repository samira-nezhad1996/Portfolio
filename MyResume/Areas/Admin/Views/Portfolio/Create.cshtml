@model Application.ViewModels.Portfolio.CreatePortfolioViewModel
@{
    ViewData["Title"] = "ثبت پورتفولیو جدید";
}

<h2>ثبت پورتفولیو جدید</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group mb-2">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="ShortDescription"></label>
        <textarea asp-for="ShortDescription" class="form-control"></textarea>
        <span asp-validation-for="ShortDescription" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="Picture"></label>
        <input asp-for="Picture" type="file" class="form-control" />
        <span asp-validation-for="Picture" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="Url"></label>
        <input asp-for="Url" class="form-control" />
        <span asp-validation-for="Url" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success mt-2">ثبت</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">بازگشت</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
