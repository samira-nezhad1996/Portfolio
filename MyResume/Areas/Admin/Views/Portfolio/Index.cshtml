@model List<Application.ViewModels.Portfolio.PortfolioViewModel>
@{
    ViewData["Title"] = "لیست پورتفولیوها";
}

<h2>لیست پورتفولیوها</h2>

<a asp-action="Create" class="btn btn-primary mb-3">ثبت پورتفولیو جدید</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>عنوان</th>
            <th>تصویر</th>
            <th>عملیات</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>
                    @if (!string.IsNullOrWhiteSpace(item.Picture))
                    {
                        <img src="@item.Picture" alt="@item.Title" style="max-width: 100px; max-height: 70px;" />
                    }
                    else
                    {
                        <span>--- ندارد ---</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">ویرایش</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('آیا مطمئنید؟');">حذف</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
